{
  "name": "wezzard-blog",
  "private": true,
  "description": "WeZZard's blog system",
  "version": "0.0.1",
  "author": "WeZZard <me@WeZZard.com>",
  "bugs": {
    "url": "https://github.com/WeZZard/blog/issues"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-brands-svg-icons": "^6.5.1",
    "@fortawesome/free-regular-svg-icons": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@mdx-js/react": "^2.3.0",
    "debug": "^4.3.4",
    "gatsby": "^5.13.0",
    "gatsby-plugin-catch-links": "^5.13.0",
    "gatsby-plugin-feed": "^5.13.0",
    "gatsby-plugin-image": "^3.13.0",
    "gatsby-plugin-manifest": "^5.13.0",
    "gatsby-plugin-mdx": "^5.13.0",
    "gatsby-plugin-offline": "^6.13.0",
    "gatsby-plugin-react-helmet": "^6.13.0",
    "gatsby-plugin-sass": "^6.13.0",
    "gatsby-plugin-sharp": "^5.13.0",
    "gatsby-plugin-web-font-loader": "^1.0.4",
    "gatsby-remark-copy-linked-files": "^6.13.0",
    "gatsby-remark-mdx-images": "file:plugins/gatsby-remark-mdx-images",
    "gatsby-source-filesystem": "^5.13.0",
    "gatsby-transformer-sharp": "^5.13.0",
    "gatsby-transformer-yaml": "^5.13.0",
    "i18n-locales": "0.0.2",
    "katex": "^0.16.9",
    "prism-react-renderer": "^2.3.1",
    "prismjs": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^5.2.1",
    "react-katex": "^2.0.2",
    "react-media": "^1.10.0",
    "remark-math": "^3.0.1",
    "styled-components": "^5.3.11",
    "unist-util-visit": "^2.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "babel-jest": "^29.7.0",
    "babel-preset-gatsby": "^3.13.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.33.2",
    "gatsby-plugin-robots-txt": "^1.8.0",
    "gatsby-plugin-sitemap": "^6.13.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "react-test-renderer": "^18.2.0",
    "sass": "^1.69.7",
    "stylelint": "^15.11.0",
    "stylelint-config-recommended": "^13.0.0",
    "stylelint-config-recommended-scss": "^13.1.0",
    "stylelint-prettier": "^4.1.0",
    "stylelint-scss": "^5.3.2"
  },
  "homepage": "https://github.com/WeZZard/blog#readme",
  "keywords": [
    "gatsby",
    "blog",
    "WeZZard"
  ],
  "license": "MIT",
  "main": "n/a",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WeZZard/blog.git"
  },
  "scripts": {
    "eslint": "eslint ./gatsby-browser.js ./gatsby-config.js ./gatsby-node.js ./gatsby-ssr.js ./src ./core",
    "eslint-fix": "eslint --fix ./gatsby-browser.js ./gatsby-config.js ./gatsby-node.js ./gatsby-ssr.js ./src ./core",
    "stylelint": "stylelint --config ./.stylelintrc.yaml ./src/**/*.scss",
    "format-check": "prettier --config ./.prettierrc.yaml --check '.*.yaml' './src/**/.*.yaml' './core/**/.*.yaml' '*.json' '*.js' 'core/**/*.js' 'src/**/*.js' 'src/**/*.scss' '*.md' 'content/**/*.md' 'content/**/*.mdx'",
    "format-write": "prettier --config ./.prettierrc.yaml --write '.*.yaml' './src/**/.*.yaml' './core/**/.*.yaml' '*.json' '*.js' 'core/**/*.js' 'src/**/*.js' 'src/**/*.scss' '*.md' 'content/**/*.md' 'content/**/*.mdx'",
    "lint": "npm run eslint; npm run stylelint;",
    "format": "npm run format-check",
    "test": "jest",
    "develop": "./clear_cache; gatsby develop -H 0.0.0.0",
    "serve": "gatsby serve -H 0.0.0.0",
    "build": "./clear_cache; gatsby build",
    "start": "npm run develop",
    "build-and-serve": "./clear_cache; gatsby build; gatsby serve -H 0.0.0.0"
  }
}
